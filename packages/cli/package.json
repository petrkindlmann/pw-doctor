{
  "name": "pw-doctor",
  "version": "0.1.0",
  "type": "module",
  "description": "AI-powered Playwright test selector maintenance",
  "repository": {
    "type": "git",
    "url": "https://github.com/petrkindlmann/pw-doctor.git"
  },
  "author": "petrkindlmann",
  "homepage": "https://github.com/petrkindlmann/pw-doctor#readme",
  "bugs": {
    "url": "https://github.com/petrkindlmann/pw-doctor/issues"
  },
  "bin": {
    "pw-doctor": "./dist/bin/pw-doctor.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./reporter": {
      "types": "./dist/reporter/index.d.ts",
      "import": "./dist/reporter/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.78.0",
    "@babel/parser": "^7.26.0",
    "@babel/traverse": "^7.26.0",
    "@babel/types": "^7.26.0",
    "@clack/prompts": "^0.10.0",
    "@pw-doctor/shared": "*",
    "chalk": "^5.4.0",
    "cheerio": "1.0.0",
    "chokidar": "5.0.0",
    "cli-table3": "^0.6.5",
    "commander": "^13.1.0",
    "cosmiconfig": "^9.0.0",
    "openai": "6.27.0",
    "ora": "^8.2.0",
    "recast": "^0.23.9",
    "zod": "^3.24.0"
  },
  "bundleDependencies": [
    "@pw-doctor/shared"
  ],
  "peerDependencies": {
    "@playwright/test": ">=1.40.0"
  },
  "peerDependenciesMeta": {
    "@playwright/test": {
      "optional": true
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@types/babel__traverse": "7.28.0",
    "@types/node": "^22.0.0",
    "domhandler": "5.0.3",
    "eslint": "^9.0.0",
    "eslint-plugin-security": "^3.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "8.59.4",
    "vitest": "^3.0.0"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "playwright",
    "testing",
    "selectors",
    "self-healing",
    "ast"
  ],
  "license": "MIT"
}
